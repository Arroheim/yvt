# Function to parse command line arguments
parse_args() {
    usage() {
        echo -e "\e[1myvt\e[0m — Yandex Video Translate v$VERSION\n"
        echo -e "\e[1m${MESSAGES[${lang_app}_usage]}:\e[0m"
        echo -e "  yvt [options] [args] <link>\n"
        echo -e "\e[1m${MESSAGES[${lang_app}_args]}:\e[0m"
        echo -e "  -v — ${MESSAGES[${lang_app}_args_volume]}"
        echo -e "  -b — ${MESSAGES[${lang_app}_args_bitrate]}"
        echo -e "  -c — ${MESSAGES[${lang_app}_args_copymode]}"
        echo -e "  -f — ${MESSAGES[${lang_app}_args_file]}"
        echo -e "  -o — ${MESSAGES[${lang_app}_args_orig]}"
        echo -e "  -l — ${MESSAGES[${lang_app}_args_lang]}"
        echo -e "  -s — ${MESSAGES[${lang_app}_args_subs]}\n"
        echo -e "\e[1m${MESSAGES[${lang_app}_options]}:\e[0m"
        echo -e "  --help — ${MESSAGES[${lang_app}_options_help]}"
        echo -e "  --version — ${MESSAGES[${lang_app}_options_version]}\n"
        echo -e "\e[1m${MESSAGES[${lang_app}_examples]}:\e[0m"
        echo -e "  yvt -v 0.5 -b 800 'https://www.youtube.com/watch?v=example_video'"
        echo -e "  yvt -v .2 -b 500 -f ./linklist.txt"
    }

    # Check the number of arguments passed
    if [ $# -eq 0 ]; then
        usage
        exit 1
    fi

    while getopts ":c:v:b:f:o:l:s:-:" opt; do
        case ${opt} in
        v)
            # Check if the entered value is in the valid range
            if [[ ! $OPTARG =~ ^(\.[0-9]+|[0-9]+(\.[0-9]*)?)$ ]]; then
                echo "${MESSAGES[${lang_app}_volume_error]}" 1>&2
                exit 1
            fi
            if (($(awk 'BEGIN { print ('"$OPTARG"' < 0.0 || '"$OPTARG"' > 0.6) }'))); then
                echo "${MESSAGES[${lang_app}_volume_error]}" 1>&2
                exit 1
            fi
            original_sound_ratio=$OPTARG
            ;;
        b)
            # Check if the bitrate is a valid number within the specified range
            if [[ ! $OPTARG =~ ^[0-9]+$ ]]; then
                echo "${MESSAGES[${lang_app}_bitrate_error]}" >&2
                exit 1
            fi
            if ((OPTARG < 50 || OPTARG > 20000)); then
                echo "${MESSAGES[${lang_app}_bitrate_error]}" >&2
                exit 1
            fi
            bitrate=$OPTARG
            ;;
        f)
            file_input=$OPTARG
            if [ ! -f "$file_input" ]; then
                echo "${MESSAGES[${lang_app}_file_not_exist_error]} $file_input" >&2
                exit 1
            fi
            ;;
        l)
            if [[ ! "$OPTARG" =~ ^(en|ru|kk)$ ]]; then
                echo "${MESSAGES[${lang_app}_invalid_translate_language]}" >&2
                exit 1
            fi
            translation_lang="--reslang=$OPTARG"
            ;;
        s)
            if [[ ! "$OPTARG" =~ ^(en|ru|kk|zh|ko|ar|fr|it|es|de|ja)$ ]]; then
                echo "${MESSAGES[${lang_app}_invalid_subs_language]}" >&2
                exit 1
            fi
            subs_lang="--reslang=$OPTARG"
            ;;
        o)
            if [[ ! "$OPTARG" =~ ^(en|ru|kk|zh|ko|ar|fr|it|es|de|ja)$ ]]; then
                echo "${MESSAGES[${lang_app}_invalid_source_language]}" >&2
                exit 1
            fi
            original_lang=$OPTARG
            ;;
        c)
            if [[ "$OPTARG" == "1" ]]; then
                copy_mode=true
            elif [[ "$OPTARG" == "0" ]]; then
                copy_mode=false
            else
                echo "${MESSAGES[${lang_app}_invalid_param]} $OPTARG" >&2
                exit 1
            fi
            ;;
        -)
            case "${OPTARG}" in
            help)
                usage
                exit 0
                ;;
            version)
                echo "Yandex Video Translate v$VERSION"
                exit 0
                ;;
            *)
                echo "${MESSAGES[${lang_app}_invalid_param]} --$OPTARG" 1>&2
                exit 1
                ;;
            esac
            ;;
        \?)
            echo "${MESSAGES[${lang_app}_invalid_param]} $OPTARG" 1>&2
            exit 1
            ;;
        :)
            echo "${MESSAGES[${lang_app}_invalid_param]} $OPTARG" 1>&2
            exit 1
            ;;
        esac
    done

    shift $((OPTIND - 1))

    if [ -n "${file_input:-}" ]; then
        exec 3<"$file_input"
        while IFS= read -r line <&3; do
            parse_link "$line" || true
        done
        exec 3<&-
        exit 0
    fi

    video_link="${*: -1}"
    parse_link "$video_link" || true

    if [ -z "$video_link" ]; then
        echo "${MESSAGES[${lang_app}_link_required_error]}"
        usage
        exit 1
    fi
}

# Function to process each link
parse_link() {
    video_link="$1"
    tput cuu1 || true
    tput el || true
    echo -e "🔗 ${MESSAGES[${lang_app}_link]}: \e[1m$video_link\e[0m"

    video_codec="libx264"

    case "$(uname -s)" in
    Darwin)
        if ffmpeg -hide_banner -encoders 2>/dev/null | grep -q h264_videotoolbox; then
            video_codec="h264_videotoolbox"
            cuda="-hwaccel videotoolbox"
        fi
        ;;
    Linux)
        if nvidia-smi &>/dev/null; then
            cuda="-hwaccel cuda -hwaccel_output_format cuda"
        fi

        if lspci | grep -iE "vga.*nvidia|nvidia.*vga" &>/dev/null; then
            video_codec="h264_nvenc"
        elif lspci | grep -iE "vga.*amd|amd.*vga" &>/dev/null; then
            video_codec="libx264"
        elif lspci | grep -iE "vga.*intel|intel.*vga" &>/dev/null; then
            video_codec="libx264"
        fi
        ;;
    esac

    original_sound_ratio=${original_sound_ratio:-0.3}
    bitrate=${bitrate:-450}
    temp_dir=./temp
    temp_video_dir=$temp_dir/video
    temp_audio_dir=$temp_dir/audio
    temp_subs_dir=$temp_dir/subtitles
    temp_video="$temp_video_dir/%(title)s"

    if [ -d "$temp_dir" ]; then
        rm -rf "$temp_dir"
    fi

    mkdir "$temp_dir" && mkdir "$temp_video_dir" && mkdir "$temp_audio_dir" && mkdir "$temp_subs_dir"

    attempts=0
    while ! yt-dlp --progress --quiet -o "$temp_video" "$video_link" && ((attempts < 10)); do
        ((attempts++))
        echo "${MESSAGES[${lang_app}_loading_error]} ${MESSAGES[${lang_app}_retrying]}$attempts"
        sleep 5
    done

    video_full_name=$(basename "$(find "$temp_video_dir" -type f | head -n 1 || true)")
    if [ -z "$video_full_name" ] || [ "$video_full_name" == "." ]; then
        echo "${MESSAGES[${lang_app}_download_failed_error]}" >&2
        rm -rf "$temp_dir"
        return 1
    fi

    lively_voice_args=()
    if [[ -n "${YANDEX_API_TOKEN:-}" ]] && [[ "${original_lang:-en}" == "en" ]] && [[ "$translation_lang" == "--reslang=ru" ]]; then
        lively_voice_args=(--lively-voice "--api-token=$YANDEX_API_TOKEN")
    fi

    NODE_OPTIONS='--no-deprecation' vot-cli --outdir="$temp_audio_dir" "${lively_voice_args[@]}" "$translation_lang" "$video_link" >/dev/null || true
    audio_full_name=$(find "$temp_audio_dir" -type f | head -n 1 || true)
    if [ -z "$audio_full_name" ]; then
        echo "${MESSAGES[${lang_app}_translation_failed_error]}" >&2
        rm -rf "$temp_dir"
        return 1
    fi

    NODE_OPTIONS='--no-deprecation' vot-cli --outdir="$temp_subs_dir" --subs "$subs_lang" "$video_link" >/dev/null || true
    subs_full_name=$(find "$temp_subs_dir" -type f | head -n 1 || true)
    if [ -z "$subs_full_name" ]; then
        echo "${MESSAGES[${lang_app}_subs_unavailable_warning]}"
    fi

    source_video_codec=$(ffprobe -v error -select_streams v:0 -show_entries stream=codec_name -of default=noprint_wrappers=1:nokey=1 "$temp_video_dir/$video_full_name" || true)
    source_audio_codec=$(ffprobe -v error -select_streams a:0 -show_entries stream=codec_name -of default=noprint_wrappers=1:nokey=1 "$temp_video_dir/$video_full_name" || true)

    if [ "$source_video_codec" == "h264" ] && [ "$source_audio_codec" == "aac" ] && [ "${copy_mode:-false}" == true ]; then
        video_codec="copy"
    fi

    echo -e "🔊 ${MESSAGES[${lang_app}_volume]}: \e[1m$original_sound_ratio\e[0m"
    echo -e "📈 ${MESSAGES[${lang_app}_bitrate]}: \e[1m$bitrate Kbit\e[0m"
    echo -e "📹 ${MESSAGES[${lang_app}_encoder]}: \e[1m$video_codec\e[0m"
    echo -e "📄 ${MESSAGES[${lang_app}_filename]}: \e[1m${video_full_name%.*}.mp4\e[0m"

    if [ "$source_video_codec" != "h264" ] || [ "$source_audio_codec" != "aac" ]; then
        # shellcheck disable=SC2086 # $cuda intentionally expands to multiple ffmpeg flags
        ffmpeg \
            ${cuda:-} \
            -hide_banner -v quiet -stats -i "$temp_video_dir/$video_full_name" \
            -c:v "$video_codec" -b:v "$bitrate"K -crf 23 -preset medium -c:a aac \
            "$temp_video_dir/${video_full_name%.*}".mp4 || true

        tput cuu1 || true
        tput el || true

        rm "$temp_video_dir/$video_full_name" || true
        video_full_name=$(basename "$(find "$temp_video_dir" -type f | head -n 1 || true)")
        video_codec="copy"
    fi

    ffmpeg_subs_input=()
    ffmpeg_subs_map=()
    ffmpeg_subs_codec=()
    if [ -n "$subs_full_name" ]; then
        ffmpeg_subs_input=(-i "$subs_full_name")
        ffmpeg_subs_map=(-map 2:s)
        ffmpeg_subs_codec=(-c:s mov_text -metadata:s:s:0 "language=${FFMPEG_LANG_NAMES[${subs_lang#--reslang=}]:-english}")
    fi

    # shellcheck disable=SC2086 # $cuda intentionally expands to multiple ffmpeg flags
    if ffmpeg \
        ${cuda:-} \
        -hide_banner -v quiet -stats \
        -i "$temp_video_dir/$video_full_name" -i "$audio_full_name" "${ffmpeg_subs_input[@]}" \
        -c:v "$video_codec" -b:v "$bitrate"K -crf 23 -preset medium \
        -filter_complex "[0:a] volume=$original_sound_ratio [original]; \
        [original][1:a] amix=inputs=2:duration=longest [mixed_audio]; \
        [0:a] volume=1 [original_audio]" \
        -map 0:v -map "[mixed_audio]" -map "[original_audio]" "${ffmpeg_subs_map[@]}" \
        "${ffmpeg_subs_codec[@]}" \
        -metadata:s:a:0 "language=${FFMPEG_LANG_NAMES[${translation_lang#--reslang=}]:-russian}" \
        -metadata:s:a:1 "language=${FFMPEG_LANG_NAMES[${original_lang:-en}]:-english}" \
        -y "$video_full_name"; then

        tput cuu1 || true
        tput el || true

        echo -e "👍 ${MESSAGES[${lang_app}_done]}"
        echo
    else
        echo -e "❌ ${MESSAGES[${lang_app}_fail]}"
        echo
    fi
    rm -rf "$temp_dir" || true
}

# Parse command line arguments
